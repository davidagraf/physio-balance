{
  "name": "physio-balance",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "start": "node ./node_modules/webpack-dev-server/bin/webpack-dev-server.js --history-api-fallback --port 9000 --colors --config ./webpack.dev.js",
    "dist": "rm -rf dist && node ./node_modules/webpack/bin/webpack.js --colors --config ./webpack.dist.js",
    "deploy_rm": "gsutil -m rm -r gs://www.physiobalance.fit/*",
    "deploy_upload": "gsutil -m rsync -R dist/ gs://www.physiobalance.fit",
    "deploy_publish": "gsutil -m acl ch -r -u AllUsers:R gs://www.physiobalance.fit/*",
    "deploy_cache": "gsutil setmeta -h \"Cache-Control: no-cache, no-store, must-revalidate, private\" gs://www.physiobalance.fit/index.html",
    "deploy": "npm run dist && npm run deploy_rm && npm run deploy_upload && npm run deploy_publish && npm run deploy_cache"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@bitbucket.org/davidagraf/physio-balance.git"
  },
  "author": "",
  "license": "ISC",
  "homepage": "https://bitbucket.org/davidagraf/physio-balance#readme",
  "devDependencies": {
    "autoprefixer-loader": "3.2.0",
    "babel-core": "6.16.0",
    "babel-loader": "6.2.5",
    "babel-plugin-transform-object-rest-spread": "6.8.0",
    "babel-polyfill": "6.13.0",
    "babel-preset-es2015": "6.14.0",
    "babel-preset-react": "6.11.1",
    "babel-runtime": "6.11.6",
    "css-loader": "0.25.0",
    "eslint": "3.6.1",
    "eslint-loader": "1.5.0",
    "eslint-plugin-react": "6.3.0",
    "extract-text-webpack-plugin": "1.0.1",
    "file-loader": "0.9.0",
    "font-awesome": "4.6.3",
    "history": "2.1.0",
    "html-webpack-plugin": "2.22.0",
    "jquery": "3.1.1",
    "keymirror": "0.1.1",
    "moment": "2.15.1",
    "node-sass": "3.10.0",
    "normalize.css": "4.2.0",
    "react": "15.3.2",
    "react-addons-css-transition-group": "15.3.2",
    "react-dom": "15.3.2",
    "react-redux": "4.4.5",
