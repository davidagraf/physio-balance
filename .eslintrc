{
  "ecmaFeatures": {
    "modules": true
  },
  "env": {
    "es6": true,
    "node": true
  },
  "rules": {
    "quotes": [2, "single"],
    "strict": [2, "global"],
    "no-underscore-dangle": [0],
    "indent": [2, 2],
    "max-len": [2, 120],
    "no-bitwise": [2],
    "wrap-iife": [2],
    "complexity": [2, 10],
    "max-depth": [2, 3],
    "max-params": [2, 5],
    "no-undefined": [1],
    "valid-jsdoc": [2],
    "no-console": [1]
  }
}
