{
  "parserOptions": {
    "ecmaVersion": 6,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "env": {
    "browser": true,
    "node": true,
    "es6": true
  },
  "plugins": [
    "react"
  ],
  "rules": {
    "quotes": [2, "single"],
    "strict": [2, "global"],
    "no-underscore-dangle": [0],
    "indent": [2, 2],
    "max-len": [2, 120],
    "no-bitwise": [2],
    "wrap-iife": [2],
    "complexity": [2, 10],
    "max-depth": [2, 3],
    "max-params": [2, 5],
    "no-undef": [1],
    "valid-jsdoc": [2],
    "no-console": [1],
    "jsx-quotes": [2, "prefer-double"],
    "no-unreachable": [1],
    "no-unused-vars": [2],
    "eqeqeq": [2],
    "react/jsx-no-undef": 1,
    "react/prop-types": 1,
    "react/jsx-wrap-multilines": 1,
    "react/self-closing-comp": 1,
    "react/no-did-mount-set-state": 1,
    "react/no-did-update-set-state": 1,
    "react/jsx-uses-react": 1,
    "react/jsx-uses-vars": 1,
    "react/react-in-jsx-scope": 1,
    "react/no-unknown-property": 1,
    "react/jsx-no-duplicate-props": 1,
    "react/no-danger": 1
  }
}
